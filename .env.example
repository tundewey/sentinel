# Set exactly one of USE_OPEN_ROUTER or USE_BEDROCK to true
USE_OPEN_ROUTER=false
USE_BEDROCK=false

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
RESEND_API_KEY=
RESEND_FROM="Sentinel <onboarding@resend.dev>"
REMINDER_INTERVAL_SECONDS=60
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWKS_URL=
S3_BUCKET=
OPENAI_API_KEY=
DEFAULT_AWS_REGION=
AWS_ACCOUNT_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=
BEDROCK_REGION=

# Aurora Data API (required for backend persistence)
AURORA_CLUSTER_ARN=
AURORA_SECRET_ARN=
AURORA_DATABASE=sentinel
LOCAL_DB_PATH=./sentinel.db

# Comma-separated: which severities trigger Settings integrations (Slack / webhooks / PagerDuty).
# For demos, you can use: medium,high,critical
INTEGRATION_NOTIFY_SEVERITIES=high,critical

# Optional link appended to Slack / generic webhook payloads (no trailing slash).
# SENTINEL_PUBLIC_URL=https://your-cloudfront-domain
